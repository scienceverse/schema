{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scienceverse.org/schema/paper.json",
  "title": "Bibr Paper",
  "description": "A research paper, as processed by bibr",
  "type": "object",
  "properties": {
    "paper_id": {
      "description": "A unique ID for each paper (usually the bibr file_hash)",
      "type": ["string", "null"]
    },
    "info": { 
      "$ref": "#/$defs/info" 
    },
    "authors": {
      "type": "array",
      "items": { "$ref": "#/$defs/author" }, 
      "uniqueItems": true
    },
    "text": {
      "type": "array",
      "items": { "$ref": "#/$defs/sentence" }, 
      "uniqueItems": true
    },
    "sections": {
      "type": "array",
      "items": { "$ref": "#/$defs/section" }, 
      "uniqueItems": true
    },
    "links": {
      "type": "array",
      "items": { "$ref": "#/$defs/link" }, 
      "uniqueItems": true
    },
    "bib": {
      "type": "array",
      "items": { "$ref": "#/$defs/biblio_ref"}, 
      "uniqueItems": true
    },
    "bib_matches": {
      "type": "array",
      "items": { "$ref": "#/$defs/biblio_match"}, 
      "uniqueItems": true
    },
    "xrefs": {
      "type": "array",
      "items": { "$ref": "#/$defs/xref" }, 
      "uniqueItems": true
    },
    "figs": {
      "type": "array",
      "items": { "$ref": "#/$defs/fig" }, 
      "uniqueItems": true
    },
    "tbls": {
      "type": "array",
      "items": { "$ref": "#/$defs/tbl" }, 
      "uniqueItems": true
    },
    "equations": {
      "type": "array",
      "items": { "$ref": "#/$defs/equation" }
    }
  },

  "required": [
    "paper_id",
    "info",
    "authors", 
    "text",
    "sections",
    "links",
    "bib",
    "bib_matches",
    "xrefs",
    "figs",
    "tbls",
    "equations"
  ],

  "additionalProperties": false,
  
  "$defs": {
    "info": {
      "type": "object",
      "required": [
        "title", 
        "description", 
        "keywords", 
        "doi", 
        "file_hash", 
        "input_format", 
        "file_name", 
        "bibr_version", 
        "paper_type", 
        "paper_type_confidence", 
        "oecd_l1", 
        "oecd_l2", 
        "oecd_confidence"
      ],
      "properties": {
        "title": { "type": "string" }, 
        "description": { "type": ["string", "null"] }, 
        "keywords": {
          "type": "array",
          "items": { "type": "string" }
        }, 
        "doi": { 
          "type": ["string", "null"],
          "pattern": "^10\\.\\d{4,9}/\\S+$"
        }, 
        "file_hash": { 
          "type": "string", 
          "pattern": "^[a-f0-9]{14}$"
        },
        "input_format": {
          "type": "string",
          "enum": [
            "pdf",
            "html",
            "docx",
            "doc",
            "md",
            "unknown"
          ]
        }, 
        "file_name": {  "type": "string" }, 
        "bibr_version": { "type": "string" }, 
        "paper_type": {
          "type": "string",
          "enum": [
            "empirical",
            "unknown"
          ]
        }, 
        "paper_type_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }, 
        "oecd_l1": {
          "description": "OECD Research Area, Level 1",
          "type": ["string", "null"],
          "enum": [
            "Natural Sciences",
            "Engineering and Technology",
            "Medical and Health Sciences",
            "Agricultural and Veterinary Sciences",
            "Social Sciences",
            "Humanities and the arts",
            null
          ]
        }, 
        "oecd_l2": {
          "description": "OECD Research Area, Level 2",
          "type": ["string", "null"],
          "enum": [
            "Mathematics",
            "Computer and information sciences",
            "Physical sciences",
            "Chemical sciences",
            "Earth and related environmental sciences",
            "Biological sciences",
            "Other natural sciences",
            "Civil engineering",
            "Electrical engineering, electronic engineering, information engineering",
            "Mechanical engineering",
            "Chemical engineering",
            "Materials engineering",
            "Medical engineering",
            "Environmental engineering",
            "Environmental biotechnology",
            "Industrial biotechnology",
            "Nano-technology",
            "Other engineering and technologies",
            "Basic medical research",
            "Clinical medicine",
            "Health sciences",
            "Medical biotechnology",
            "Other medical science",
            "Agriculture, forestry, fisheries",
            "Animal and dairy science",
            "Veterinary science",
            "Other agricultural science",
            "Psychology and cognitive science",
            "Economics and business",
            "Educational sciences",
            "Sociology",
            "Law",
            "Political science",
            "Social and economic geography",
            "Media and communication",
            "Other social sciences",
            "History and archeology",
            "Languages and literature",
            "Philosophy, ethics and religion",
            "Art",
            "Other Humanities",
            null
          ]
        }, 
        "oecd_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "author": {
      "type": "object",
      "required": [ 
        "author_id", 
        "given", 
        "family", 
        "affiliation", 
        "email", 
        "corresponding", 
        "orcid"
      ],
      "properties": {
        "author_id": { 
          "type": "integer"
        }, 
        "given": { "type": ["string", "null"] }, 
        "family": { "type": ["string", "null"] }, 
        "affiliation": { "type": ["string", "null"] }, 
        "email": { 
          "type": ["string", "null"],
          "format": "email"
        }, 
        "corresponding": { "type": "boolean" }, 
        "orcid": { 
          "type": ["string", "null"],
          "pattern": "^\\d{4}-\\d{4}-\\d{4}-\\d{3}[\\dX]$" 
        }, 
        "role": { 
          "type": "array",
          "items": { "type": ["string", "null"] }
        }
      }
    },
    "sentence": {
      "type": "object",
      "required": ["text_id", "section_id", "paragraph_id", "text"],
      "properties": {
        "text_id": { 
          "type": "integer"
        },
        "section_id": { "type": "integer" },
        "paragraph_id": { "type": "integer" },
        "text": { "type": "string" }
      }
    },
    "section": {
      "type": "object",
      "required": ["section_id", 
                   "header", 
                   "parent_section_id", 
                   "section_type", 
                   "classification_score"],
      "properties": {
        "section_id": { 
          "type": "integer" 
        },
        "header": { "type": "string" },
        "parent_section_id": { "type": "integer" }, 
        "section_type": { 
          "type": "string",
          "enum": [
            "abstract",
            "intro",
            "method",
            "results",
            "discussion",
            "references",
            "acknowledgment",
            "funding",
            "endnote",
            "footnote",
            "tbl_cap",
            "fig_cap",
            "unknown"
          ]
        }, 
        "classification_score": { 
          "type": "number", 
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "link": {
      "type": "object",
      "required": ["url", "text_id"],
      "properties": {
        "url": { 
          "type": "string", 
          "format": "uri" 
        },
        "link_text": { "type": ["string", "null"] },
        "text_id": { "type": "integer" }
      }
    },
    "xref": {
      "type": "object",
      "required": ["xref_id", "xref_type", "contents", "text_id"],
      "properties": {
        "xref_id": { 
          "type": "integer", 
          "description": "The ID from the bib, tbl, fig, or text table (for footnotes)"
        }, 
        "xref_type": { 
          "type": "string",
          "enum": [
            "bib",
            "tbl",
            "fig",
            "footnote"
          ]
        }, 
        "contents": { "type": ["string", "null"] }, 
        "text_id": { 
          "type": "integer", 
          "description": "The ID from the text table for the sentence containing the reference to this object."
        }
      }
    },
    "biblio": {
      "type": "object",
      "required": [
        "bib_id",
        "bib_type",
        "title",
        "authors",
        "publication_year"
      ],
      "properties": {
        "bib_id": {
          "type": "integer",
          "description": "Paper-specific ID"
        },
        "bib_type": {
          "type": "string",
          "enum": [
            "journal_article",
            "book",
            "book_chapter",
            "dataset",
            "software",
            "preprint",
            "conference_paper",
            "report",
            "other"
          ]
        },
        "doi": {
          "type": ["string", "null"],
          "pattern": "^10\\.\\d{4,9}/\\S+$"
        },
        "title": { "type": "string" },
        "authors": {
          "type": "string",
          "description": "Pipe-separated full (last, given) author/creator names in order"
        },
        "editors": {
          "type": "string",
          "description": "Pipe-separated full (last, given) editor names in order"
        },
        "publisher": {
          "type": "string"
        },
        "publication_year": {
          "type": "integer"
        },
        "publication_date": {
          "type": "string",
          "format": "date"
        },
        "container": {
          "type": "string",
          "description": "Journal or book title"
        },
        "volume": { "type": "string" },
        "issue": { "type": "string" },
        "pages": { "type": "string" },
        "edition": { "type": "string" },
        "version": { "type": "string" },
        "url": { 
          "type": "string",
          "format": "uri" 
        }
      }
    },
    "biblio_ref": {
      "type": "object",
      "allOf": [
        { "$ref": "#/$defs/biblio" },
        {
          "type": "object",
          "required": ["text_id"],
          "properties": {
            "text_id": { 
              "type": "integer",
              "description": "The text table ID of the reference exactly as written in the paper"
            }
          }
        }
      ]
    },
    "biblio_match": { 
      "type": "object",
      "allOf": [
        { "$ref": "#/$defs/biblio" },
        {
          "type": "object",
          "required": ["source"],
          "properties": {
            "source": {
              "type": "string",
              "description": "Metadata source",
              "enum": [
                "crossref",
                "datacite",
                "openalex",
                "manual"
              ]
            },
            "match_score": { 
               "description": "A score describing the match between the original reference and the entry from source",
              "type": "number",
              "minimum": 0,
              "maximum": 100
            }
          }
        }
      ]
    },
    "tbl": {
      "type": "object",
      "required": [ "tbl_id", "section_id"],
      "properties": {
        "tbl_id": {
          "description": "A unique ID for each table",
          "type": "integer"
        },
        "section_id": {
          "description": "The ID from the sections table for this table",
          "type": "integer"
        },
        "contents": {
          "description": "The table contents as tabular data",
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": ["string", "number", "boolean", "null"] }
          }
        }
      }
    },
    "fig": {
      "type": "object",
      "required": [ "fig_id", "section_id"],
      "properties": {
        "fig_id": {
          "description": "A unique ID for each figure",
          "type": "integer" 
        },
        "section_id": {
          "description": "The ID from the sections table for this figure",
          "type": "integer"
        },
        "image": {
          "description": "The base64 image or reference to it (undecided)",
          "type": "string",
          "contentEncoding": "base64"
        }
      }
    },
    "equation": {
      "type": "object",
      "required": ["text_id", "grp_id", "lhs", "comp", "rhs"],
      "properties": {
        "text_id": { 
          "description": "ID from the text table for the source of the equation",
          "type": "integer"
        },
        "grp_id": { 
          "description": "Grouping within a sentence (e.g., multiple equations that are grouped by brackets) or table",
          "type": "integer" 
        },
        "lhs": { 
          "description": "Left-hand side of the equation",
          "type": "string" 
        },
        "comp": { 
           "description": "Comparator symbol(s)",
          "type": "string" 
        },
        "rhs": { 
           "description": "Right-hand side of the equation",
          "type": "string" 
        }
      }
    }
  }
}

